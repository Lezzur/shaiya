// Prisma schema for Content Agency V1
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  TEAM
  CLIENT
}

enum AuthMethod {
  PASSWORD
  MAGIC_LINK
}

enum HealthStatus {
  HEALTHY
  AT_RISK
  CHURNED
}

enum ContentAssetType {
  SOCIAL_POST
  BLOG
  VIDEO
  ILLUSTRATION
  CAROUSEL
  STORY
  REEL
  OTHER
}

enum InternalStatus {
  DRAFT
  QA_PASSED
  SENT_TO_CLIENT
}

enum ClientStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
  DONE
}

enum ActivityModule {
  LEAD_ENGINE
  OPS_DESK
  CONTENT_ENGINE
  CLIENT_PORTAL
  PROPOSALS
  ANALYTICS
  WEBSITE
  SYSTEM
}

enum ProjectStatus {
  BRIEFING
  ASSET_PREP
  IN_PRODUCTION
  INTERNAL_REVIEW
  CLIENT_REVIEW
  REVISION
  APPROVED
  DELIVERED
}

enum DeliverableStatus {
  PENDING_D
  IN_PROGRESS_D
  DONE_D
}

enum CommentEntityType {
  PROJECT
  CONTENT_ASSET
  PROPOSAL
  BRAND_PROFILE
  CLIENT_MESSAGE
}

enum InvoiceStatus {
  DRAFT_I
  SENT_I
  PAID
  OVERDUE
  CANCELLED
}

enum PipelineStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum GenerationJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// =============================================================================
// CORE TABLES
// =============================================================================

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  role         UserRole
  avatar       String?
  capacity     Int?
  skills       String[]
  authMethod   AuthMethod @map("auth_method")
  passwordHash String?    @map("password_hash")
  clientId     String?    @map("client_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  client              Client?        @relation("UserClient", fields: [clientId], references: [id], onDelete: SetNull)
  primaryContactFor   Client[]       @relation("ClientPrimaryContact")
  assignedProjects    Project[]      @relation("ProjectAssignee")
  authoredComments    Comment[]      @relation("CommentAuthor")
  activityLogs        ActivityLog[]  @relation("ActivityActor")

  @@index([role])
  @@index([clientId])
  @@map("users")
}

model Client {
  id               String       @id @default(uuid())
  name             String
  logo             String?
  industry         String?
  packageTier      String?      @map("package_tier")
  monthlyValue     Decimal      @default(0) @map("monthly_value") @db.Decimal(10, 2)
  lifetimeValue    Decimal      @default(0) @map("lifetime_value") @db.Decimal(10, 2)
  primaryContactId String?      @map("primary_contact_id")
  healthStatus     HealthStatus @default(HEALTHY) @map("health_status")
  renewalDate      DateTime?    @map("renewal_date")
  r2BucketPath     String?      @map("r2_bucket_path")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  primaryContact User?           @relation("ClientPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  users          User[]          @relation("UserClient")
  contentAssets  ContentAsset[]  @relation("ClientContentAssets")
  projects       Project[]       @relation("ClientProjects")
  invoices       Invoice[]       @relation("ClientInvoices")
  brandProfile   BrandProfile?   @relation("ClientBrandProfile")
  generationJobs GenerationJob[] @relation("ClientGenerationJobs")

  @@index([healthStatus])
  @@map("clients")
}

model ContentAsset {
  id              String           @id @default(uuid())
  clientId        String           @map("client_id")
  projectId       String?          @map("project_id")
  generationJobId String?          @map("generation_job_id")
  type            ContentAssetType
  fileUrl         String           @map("file_url")
  thumbnailUrl    String?          @map("thumbnail_url")
  internalStatus  InternalStatus   @default(DRAFT) @map("internal_status")
  clientStatus    ClientStatus     @default(PENDING) @map("client_status")
  version         Int              @default(1)
  parentAssetId   String?          @map("parent_asset_id")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  client        Client         @relation("ClientContentAssets", fields: [clientId], references: [id], onDelete: Cascade)
  project       Project?       @relation("ProjectContentAssets", fields: [projectId], references: [id], onDelete: SetNull)
  generationJob GenerationJob? @relation("JobContentAssets", fields: [generationJobId], references: [id], onDelete: SetNull)
  parentAsset   ContentAsset?  @relation("AssetVersions", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets   ContentAsset[] @relation("AssetVersions")
  deliverables  Deliverable[]  @relation("DeliverableAsset")

  @@index([clientId])
  @@index([internalStatus])
  @@index([clientStatus])
  @@map("content_assets")
}

model ActivityLog {
  id         String         @id @default(uuid())
  timestamp  DateTime       @default(now())
  actorId    String         @map("actor_id")
  module     ActivityModule
  action     String
  entityType String         @map("entity_type")
  entityId   String         @map("entity_id")
  metadata   Json?

  // Relations
  actor User @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([timestamp(sort: Desc)])
  @@index([entityType, entityId])
  @@index([module])
  @@map("activity_log")
}

// =============================================================================
// OPS DESK TABLES
// =============================================================================

model Project {
  id                 String        @id @default(uuid())
  clientId           String        @map("client_id")
  title              String
  brief              String?       @db.Text
  status             ProjectStatus @default(BRIEFING)
  deadline           DateTime?
  assignedToId       String?       @map("assigned_to_id")
  templateId         String?       @map("template_id")
  timeTrackedMinutes Int           @default(0) @map("time_tracked_minutes")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  client        Client         @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo    User?          @relation("ProjectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  contentAssets ContentAsset[] @relation("ProjectContentAssets")
  deliverables  Deliverable[]  @relation("ProjectDeliverables")
  invoices      Invoice[]      @relation("ProjectInvoices")

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
  @@index([deadline])
  @@map("projects")
}

model Deliverable {
  id             String            @id @default(uuid())
  projectId      String            @map("project_id")
  title          String
  status         DeliverableStatus @default(PENDING_D)
  order          Int
  contentAssetId String?           @map("content_asset_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  project      Project       @relation("ProjectDeliverables", fields: [projectId], references: [id], onDelete: Cascade)
  contentAsset ContentAsset? @relation("DeliverableAsset", fields: [contentAssetId], references: [id], onDelete: SetNull)

  @@map("deliverables")
}

model Comment {
  id         String            @id @default(uuid())
  entityType CommentEntityType @map("entity_type")
  entityId   String            @map("entity_id")
  authorId   String            @map("author_id")
  body       String            @db.Text
  parentId   String?           @map("parent_id")
  createdAt  DateTime          @default(now()) @map("created_at")

  // Relations
  author        User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Comment[] @relation("CommentReplies")

  @@index([entityType, entityId])
  @@map("comments")
}

model Invoice {
  id                     String        @id @default(uuid())
  clientId               String        @map("client_id")
  projectId              String?       @map("project_id")
  amount                 Decimal       @db.Decimal(10, 2)
  status                 InvoiceStatus @default(DRAFT_I)
  dueDate                DateTime      @map("due_date")
  paidAt                 DateTime?     @map("paid_at")
  paymongoPaymentLinkId  String?       @map("paymongo_payment_link_id")
  paymongoPaymentLinkUrl String?       @map("paymongo_payment_link_url")
  paymongoPaymentId      String?       @map("paymongo_payment_id")
  lineItems              Json          @map("line_items")
  notes                  String?       @db.Text
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  // Relations
  client  Client   @relation("ClientInvoices", fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation("ProjectInvoices", fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

// =============================================================================
// CONTENT ENGINE TABLES
// =============================================================================

model BrandProfile {
  id              String   @id @default(uuid())
  clientId        String   @unique @map("client_id")
  colors          Json?
  typography      Json?
  toneOfVoice     String?  @map("tone_of_voice") @db.Text
  targetAudience  String?  @map("target_audience") @db.Text
  exampleUrls     String[] @map("example_urls")
  styleRefUrls    String[] @map("style_ref_urls")
  characterSheets Json?    @map("character_sheets")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  client         Client          @relation("ClientBrandProfile", fields: [clientId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[] @relation("BrandProfileJobs")

  @@index([clientId])
  @@map("brand_profiles")
}

model Pipeline {
  id             String         @id @default(uuid())
  name           String
  type           String
  status         PipelineStatus @default(ACTIVE)
  webhookUrl     String         @map("webhook_url")
  config         Json?
  lastRun        DateTime?      @map("last_run")
  totalProcessed Int            @default(0) @map("total_processed")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  promptTemplates PromptTemplate[] @relation("PipelinePrompts")
  generationJobs  GenerationJob[]  @relation("PipelineJobs")

  @@index([status])
  @@map("pipelines")
}

model PromptTemplate {
  id               String   @id @default(uuid())
  pipelineId       String?  @map("pipeline_id")
  contentType      String   @map("content_type")
  body             String   @db.Text
  version          Int      @default(1)
  performanceNotes String?  @map("performance_notes") @db.Text
  abNotes          String?  @map("ab_notes") @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  category         String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  pipeline Pipeline? @relation("PipelinePrompts", fields: [pipelineId], references: [id], onDelete: SetNull)

  @@index([pipelineId])
  @@map("prompt_templates")
}

model GenerationJob {
  id              String              @id @default(uuid())
  pipelineId      String              @map("pipeline_id")
  clientId        String              @map("client_id")
  brandProfileId  String              @map("brand_profile_id")
  params          Json
  status          GenerationJobStatus @default(QUEUED)
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  totalCost       Decimal             @default(0) @map("total_cost") @db.Decimal(8, 4)
  errorMessage    String?             @map("error_message") @db.Text
  createdAt       DateTime            @default(now()) @map("created_at")

  // Relations
  pipeline      Pipeline       @relation("PipelineJobs", fields: [pipelineId], references: [id], onDelete: Cascade)
  client        Client         @relation("ClientGenerationJobs", fields: [clientId], references: [id], onDelete: Cascade)
  brandProfile  BrandProfile   @relation("BrandProfileJobs", fields: [brandProfileId], references: [id], onDelete: Cascade)
  contentAssets ContentAsset[] @relation("JobContentAssets")
  apiUsageLogs  ApiUsageLog[]  @relation("JobUsageLogs")

  @@index([clientId, status])
  @@map("generation_jobs")
}

model ModelRegistry {
  id               String   @id @default(uuid())
  name             String
  provider         String
  endpoint         String?
  costPerUnit      Decimal  @map("cost_per_unit") @db.Decimal(10, 6)
  unitType         String   @map("unit_type")
  qualityBenchmark Decimal? @map("quality_benchmark") @db.Decimal(3, 2)
  isActive         Boolean  @default(true) @map("is_active")

  // Relations
  apiUsageLogs ApiUsageLog[] @relation("ModelUsageLogs")

  @@map("model_registry")
}

model ApiUsageLog {
  id         String   @id @default(uuid())
  jobId      String?  @map("job_id")
  modelId    String?  @map("model_id")
  modelName  String   @map("model_name")
  tokensUsed Int?     @map("tokens_used")
  cost       Decimal  @db.Decimal(8, 6)
  timestamp  DateTime @default(now())
  module     String

  // Relations
  job   GenerationJob? @relation("JobUsageLogs", fields: [jobId], references: [id], onDelete: SetNull)
  model ModelRegistry? @relation("ModelUsageLogs", fields: [modelId], references: [id], onDelete: SetNull)

  @@index([timestamp])
  @@index([module])
  @@map("api_usage_logs")
}
